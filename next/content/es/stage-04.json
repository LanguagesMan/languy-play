{"lang":"es","stage":4,"title":"fuller short sentences","sentences":[{"t":"¿Conoces esa canción?","en":"Do you know that song?","a":"n_55cd0a53b254.mp3"},{"t":"Claro que puedes.","en":"Of course you can.","a":"n_c1fbce130535.mp3"},{"t":"¿Cuánto cuesta entrar?","en":"How much does it cost to get in?","a":"n_a32c45cce2aa.mp3"},{"t":"Debería trabajar menos.","en":"I should work less.","a":"n_d3370153e158.mp3"},{"t":"Debes saber esto.","en":"You should know this.","a":"n_23098a7df12e.mp3"},{"t":"¿Hace frío fuera?","en":"Is it cold outside?","a":"n_781d9701fafa.mp3"},{"t":"Hago la tarea.","en":"I'm doing the homework.","a":"n_369b7e09d26d.mp3"},{"t":"Hice mi tarea.","en":"I did my homework.","a":"n_c09ef14f5b16.mp3"},{"t":"No hagas eso.","en":"Don't do that.","a":"n_00dae48c7b9c.mp3"},{"t":"Dime la verdad.","en":"Tell me the truth.","a":"n_3b09dc56f462.mp3"},{"t":"Dime quién fue.","en":"Tell me who it was.","a":"n_8112344675cf.mp3"},{"t":"Pregúntale a ella.","en":"Ask her.","a":"n_5d654ad89b21.mp3"},{"t":"Pregúntale cuánto quiere.","en":"Ask him how much he wants.","a":"n_80e837f1f7f0.mp3"},{"t":"Te doy uno.","en":"I'll give you one.","a":"n_ec7237acc904.mp3"},{"t":"¿Dónde lo busco?","en":"Where do I look for it?","a":"n_a315da4f889f.mp3"},{"t":"Busco mis llaves.","en":"I'm looking for my keys.","a":"n_c6c64c17e4c8.mp3"},{"t":"No lo encuentro.","en":"I can't find it.","a":"n_57a1df409a73.mp3"},{"t":"No lo vi.","en":"I didn't see it.","a":"n_5e4c8c9db4ab.mp3"},{"t":"¿Tienen una mesa?","en":"Do you have a table?","a":"n_bb35604cb9d0.mp3"},{"t":"Quiero comprar pan.","en":"I want to buy bread.","a":"n_6be65876fb12.mp3"},{"t":"Ayer fue domingo.","en":"Yesterday was Sunday.","a":"n_c268b9a3663a.mp3"},{"t":"¿Te sientes bien?","en":"Are you feeling okay?","a":"n_883f94781a4b.mp3"},{"t":"¿Cómo te sientes?","en":"How do you feel?","a":"n_22d5ed658694.mp3"},{"t":"Necesito una pastilla.","en":"I need a pill.","a":"n_cc0a7761b324.mp3"},{"t":"Soy de España.","en":"I'm from Spain.","a":"n_5a5da2562193.mp3"},{"t":"Ella está ocupada.","en":"She's busy.","a":"n_3806b1de07a8.mp3"},{"t":"Tengo que irme.","en":"I have to go.","a":"n_d8fe094b8e57.mp3"},{"t":"¿Estás enojado conmigo?","en":"Are you mad at me?","a":"n_ab6453dfdcde.mp3"},{"t":"¿Me puedes ayudar?","en":"Can you help me?","a":"n_8e6e35056778.mp3"},{"t":"Tengo veinte años.","en":"I'm twenty years old.","a":"n_dea44a0ee270.mp3"},{"t":"Necesito tu ayuda.","en":"I need your help.","a":"n_d978de393caa.mp3"},{"t":"¿Cuánto te debo?","en":"How much do I owe you?","a":"n_cf3337a0e4ae.mp3"},{"t":"No vuelvas tarde.","en":"Don't come back late.","a":"n_c591ad3f175e.mp3"},{"t":"¿Qué hiciste ayer?","en":"What did you do yesterday?","a":"n_4b7b462c6920.mp3"},{"t":"Hicimos un viaje.","en":"We took a trip.","a":"n_c8bfac255a70.mp3"},{"t":"Todos sabemos eso.","en":"We all know that.","a":"n_c5da6de9eabc.mp3"},{"t":"Nosotros no sabemos.","en":"We don't know.","a":"n_9fb1daa6bbff.mp3"},{"t":"¿Ves la casa?","en":"Do you see the house?","a":"n_9b1b6eeb1d17.mp3"},{"t":"Te lo muestro.","en":"I'll show you.","a":"n_98f23258f15c.mp3"},{"t":"Dame tu mano.","en":"Give me your hand.","a":"n_15d4d348e362.mp3"},{"t":"Prueba un poco.","en":"Try a little.","a":"n_2f63e0114794.mp3"},{"t":"Mañana es martes.","en":"Tomorrow is Tuesday.","a":"n_eb7e9f475c50.mp3"},{"t":"Espera dos minutos.","en":"Wait two minutes.","a":"n_eb8b3ad0fad3.mp3"},{"t":"Cuestan veinte euros.","en":"They cost twenty euros.","a":"n_27883b16baec.mp3"},{"t":"Tengo dos hermanos.","en":"I have two brothers.","a":"n_a23d4bc48952.mp3"},{"t":"Debes tener cuidado.","en":"You must be careful.","a":"n_9831dab475fc.mp3"},{"t":"Ellos vienen mañana.","en":"They're coming tomorrow.","a":"n_821c7b53bff6.mp3"},{"t":"Hacemos un plan.","en":"We're making a plan.","a":"n_e86fbc9d33bd.mp3"},{"t":"Hazme un favor.","en":"Do me a favor.","a":"n_edf2be10777e.mp3"},{"t":"Quiero preguntarte algo.","en":"I want to ask you something.","a":"n_9d1c37cda755.mp3"},{"t":"Conozco a María.","en":"I know María.","a":"n_7862ef06bba1.mp3"},{"t":"Búscalo en casa.","en":"Look for it at home.","a":"n_f34ea68df04b.mp3"},{"t":"Muéstrame la foto.","en":"Show me the photo.","a":"n_d45d846314d8.mp3"},{"t":"Veo la tele.","en":"I'm watching TV.","a":"n_4108eeaf3d16.mp3"},{"t":"Dame un minuto.","en":"Give me a minute.","a":"n_70c9c9d598c5.mp3"},{"t":"Mira quién llegó.","en":"Look who's here.","a":"n_864f7ac61664.mp3"},{"t":"Voy a ducharme.","en":"I'm going to take a shower.","a":"n_f957545e74b9.mp3"},{"t":"¿Te acuestas tarde?","en":"Do you go to bed late?","a":"n_067b42f1dc4a.mp3"},{"t":"¿Trabajas o estudias?","en":"Do you work or study?","a":"n_f024e8e0cba2.mp3"},{"t":"Nos levantamos juntos.","en":"We get up together.","a":"n_8f0b6ded0983.mp3"},{"t":"¿Qué me recomiendas?","en":"What do you recommend?","a":"n_944a24b1be5d.mp3"},{"t":"Odio los lunes.","en":"I hate Mondays.","a":"n_61b00358799d.mp3"},{"t":"Estamos en enero.","en":"It's January.","a":"n_f157160e7770.mp3"},{"t":"Pago en efectivo.","en":"I'll pay in cash.","a":"n_cf8629cbb116.mp3"},{"t":"Hoy pagas tú.","en":"Today you're paying.","a":"n_07eec487634e.mp3"},{"t":"Estoy enferma hoy.","en":"I'm sick today.","a":"n_6f13ad1500ce.mp3"},{"t":"Bebe mucha agua.","en":"Drink lots of water.","a":"n_2d577e8d1374.mp3"},{"t":"Dale una oportunidad.","en":"Give him a chance.","a":"n_45e58c48763f.mp3"},{"t":"Sí, soy yo.","en":"Yes, that's me.","a":"n_abc7181b4a16.mp3"},{"t":"Sí, la veo.","en":"Yes, I see it.","a":"n_a6a0a001149f.mp3"},{"t":"Sí, estoy listo.","en":"Yes, I'm ready.","a":"n_b0a0692be298.mp3"},{"t":"Muy bien, gracias.","en":"Very well, thanks.","a":"n_5e29a9e27f7b.mp3"},{"t":"No, tengo calor.","en":"No, I'm hot.","a":"n_d0aaad316308.mp3"},{"t":"No, gira allí.","en":"No, turn over there.","a":"n_893320261917.mp3"},{"t":"Hola, soy Carlos.","en":"Hi, I'm Carlos.","a":"n_43456401a7f7.mp3"},{"t":"Claro, puedes preguntar.","en":"Sure, you can ask.","a":"n_b12401ef9f67.mp3"},{"t":"Mira, ya entiendo.","en":"Look, now I get it.","a":"n_4bcf9055b1cd.mp3"},{"t":"Perdón, estoy perdido.","en":"Sorry, I'm lost.","a":"n_c1d93c8cf80e.mp3"},{"t":"Hola, ¿qué tal?","en":"Hi, how's it going?","a":"n_e15ae40e0d1d.mp3"},{"t":"Sí, quiero probarlo.","en":"Yeah, I want to try it.","a":"n_3e30aa02ab62.mp3"},{"t":"Cuando salgas, avísame.","en":"When you head out, let me know.","a":"n_92600e835b43.mp3"},{"t":"No sé qué quiero.","en":"I don't know what I want.","a":"n_e61aa3a151d0.mp3"},{"t":"No sé por qué.","en":"I don't know why.","a":"n_97bf5d8ba14b.mp3"},{"t":"No estoy en casa.","en":"I'm not home.","a":"n_25064516dda0.mp3"},{"t":"No me gusta mucho.","en":"I don't like it that much.","a":"n_0af11add5af7.mp3"},{"t":"La casa está aquí.","en":"The house is here.","a":"n_7239a378bc8d.mp3"},{"t":"Ella es de aquí.","en":"She's from here.","a":"n_e7831022d58b.mp3"},{"t":"Me gusta el café.","en":"I like coffee.","a":"n_8c930e32f837.mp3"},{"t":"¿Te gusta el café?","en":"Do you like coffee?","a":"n_a6c493bbb7b1.mp3"},{"t":"Yo no sé nada.","en":"I don't know anything.","a":"n_f4be4162d463.mp3"},{"t":"No puedo comer nada.","en":"I can't eat anything.","a":"n_deaafe9c5503.mp3"},{"t":"Voy a comer algo.","en":"I'm going to eat something.","a":"n_ec261c052646.mp3"},{"t":"Quiero algo de comer.","en":"I want something to eat.","a":"n_ec18b580a08a.mp3"},{"t":"Voy a comer ahora.","en":"I'm going to eat now.","a":"n_d4c48b0a4b0f.mp3"}]}