{"lang":"de","stage":6,"title":"longer everyday sentences","sentences":[{"t":"Ich war auf der Party.","en":"I went to the party.","a":"n_e384362b7529.mp3"},{"t":"Kommst du auf die Party?","en":"Are you coming to the party?","a":"n_0dbc562d0e5b.mp3"},{"t":"Der Bus kommt jetzt.","en":"The bus is coming now.","a":"n_8b11ac5bd1a0.mp3"},{"t":"Ich wohn ganz in der Nähe.","en":"I live close to here.","a":"n_c7b061249625.mp3"},{"t":"Er kennt jeden.","en":"He knows everyone.","a":"n_765f3135cd26.mp3"},{"t":"Mein Kopf tut weh.","en":"My head hurts.","a":"n_f1b834b7f9e8.mp3"},{"t":"Er kommt in fünf Minuten.","en":"It arrives in five minutes.","a":"n_06912a90aea4.mp3"},{"t":"Du solltest die Wahrheit sagen.","en":"You should tell the truth.","a":"n_0b1f0f0547f1.mp3"},{"t":"Du solltest dich ein bisschen ausruhen.","en":"You should rest a little.","a":"n_25bd62987be3.mp3"},{"t":"Das ist lecker.","en":"This is delicious.","a":"n_b09ed006290c.mp3"},{"t":"Ich kann nicht mehr warten.","en":"I can't wait any longer.","a":"n_3c0142c8620c.mp3"},{"t":"Ich will sehen, was passiert.","en":"I want to see what happens.","a":"n_9c27e73ef0a8.mp3"},{"t":"Ich bin in einer Stunde zurück.","en":"I'll be back in an hour.","a":"n_dc79c9501723.mp3"},{"t":"Ich will was zu trinken.","en":"I want something to drink.","a":"n_8b675de0e81c.mp3"},{"t":"Was willst du trinken?","en":"What are you going to drink?","a":"n_f05449b3c22b.mp3"},{"t":"Ich nehm Wasser.","en":"I'll have water.","a":"n_e61b7357286c.mp3"},{"t":"Diesmal zahl ich.","en":"This time I'm paying.","a":"n_add1a767f44d.mp3"},{"t":"Es ist rechts.","en":"It's on the right.","a":"n_ec67fc93789f.mp3"},{"t":"Bieg rechts ab.","en":"Turn right.","a":"n_05a2b0ffb979.mp3"},{"t":"Fahr lieber mit dem Taxi.","en":"Better go by taxi.","a":"n_d055f3c0dfd4.mp3"},{"t":"Sie ist meine Freundin.","en":"She's my friend.","a":"n_821e8da48cc4.mp3"},{"t":"Ist sie deine Freundin?","en":"Is she your friend?","a":"n_3489b67ec8c8.mp3"},{"t":"Das ist meine Freundin.","en":