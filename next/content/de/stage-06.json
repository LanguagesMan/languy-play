 mir, wie's geht.","en":"Show me how it's done.","a":"n_3b0f7f3e8917.mp3"},{"t":"Ich hab dir mein Wort gegeben.","en":"I gave you my word.","a":"n_76dd4bb4968b.mp3"},{"t":"Gibst du mir was ab?","en":"Will you give me some?","a":"n_9056cc6063a4.mp3"},{"t":"Hast du gesehen, wie er mich angeschaut hat?","en":"Did you see how he looked at me?","a":"n_79f6d0ae499c.mp3"}]}